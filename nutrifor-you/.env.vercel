# ╔══════════════════════════════════════════════════════════════════╗
# ║  NutriForYou — Vercel Environment Variables                     ║
# ║  Import this file in: Vercel → Settings → Environment Variables ║
# ║  Replace every placeholder value with your real credentials     ║
# ╚══════════════════════════════════════════════════════════════════╝

# ─── Database (Neon / Supabase / PlanetScale) ───
# Sign up at https://neon.tech (free tier) and paste your connection string
DATABASE_URL=postgresql://user:password@your-host.neon.tech/nutriforyou?sslmode=require

# ─── Auth ───
# NEXTAUTH_URL must match your Vercel deployment URL
NEXTAUTH_URL=https://your-app.vercel.app
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=GENERATE_A_SECRET_WITH_openssl_rand_-base64_32

# ─── App ───
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ─── Encryption (HIPAA/PHI) ───
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=GENERATE_WITH_openssl_rand_-hex_32

# ─── Redis (Upstash — https://upstash.com, free tier) ───
REDIS_URL=rediss://default:your-password@your-host.upstash.io:6379

# ─── S3 Storage (AWS S3 / Cloudflare R2 / Backblaze B2) ───
S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET=nutriforyou
S3_REGION=auto

# ─── AI Provider (OpenRouter — https://openrouter.ai/keys) ───
# OpenRouter gives access to 200+ models (GPT-4o, Claude, Gemini, Llama, etc.)
AI_API_KEY=sk-or-v1-your-openrouter-api-key
# Base URL — change to https://api.openai.com/v1 for direct OpenAI
AI_BASE_URL=https://openrouter.ai/api/v1
# Model — use OpenRouter format (provider/model). Examples:
#   openai/gpt-4o, anthropic/claude-3.5-sonnet, google/gemini-pro, meta-llama/llama-3-70b
AI_MODEL=openai/gpt-4o

# ─── Stripe (https://dashboard.stripe.com/apikeys) ───
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-publishable-key

# ─── Email / SMTP (Resend — https://resend.com, free tier) ───
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_FROM=noreply@yourdomain.com
