# ─── App ───
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Database ───
DATABASE_URL=postgresql://nutrify:dev_password@localhost:5432/nutriforyou

# ─── Auth ───
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-strong-secret-here

# ─── Redis ───
REDIS_URL=redis://localhost:6379

# ─── S3 Storage ───
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=nutriforyou
S3_REGION=us-east-1

# ─── AI Provider (OpenRouter by default, or any OpenAI-compatible API) ───
# Get your key at https://openrouter.ai/keys
AI_API_KEY=your-api-key-here
# Base URL — change to https://api.openai.com/v1 for direct OpenAI
AI_BASE_URL=https://openrouter.ai/api/v1
# Model — use OpenRouter format (provider/model) or plain model name for OpenAI
AI_MODEL=openai/gpt-4o
# Comma-separated fallback models tried when the primary model returns 404
# AI_FALLBACK_MODELS=google/gemini-2.0-flash-001,meta-llama/llama-3.1-8b-instruct:free
# Legacy: OPENAI_API_KEY is still supported as a fallback for AI_API_KEY

# ─── Stripe ───
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── Email ───
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@nutrifor.you

# ─── Encryption ───
ENCRYPTION_KEY=32-byte-hex-key-for-phi-encryption
